# Создать резервную копию старого .gitignore
cp .gitignore .gitignore.backup

# Создать новый .gitignore
cat > .gitignore << 'EOF'
# ==========================
# Visual Studio
# ==========================
.vs/
*.suo
*.user
*.vcxproj.user
*.db
*.opendb
.vscode/
.idea/

# ==========================
# Сборка C#/.NET
# ==========================
**/[Bb]in/
**/[Oo]bj/
*.dll
*.exe
*.pdb
*.so
*.dylib
*.app
*.cache
*.config

# ==========================
# Сборка PlatformIO/ESP32
# ==========================
firmware/.pio/
firmware/build/

# ==========================
# NuGet
# ==========================
packages/
*.nupkg
project.lock.json
project.assets.json

# ==========================
# Логи и временные файлы
# ==========================
*.log
*.bak
*.tmp
*.swp

# ==========================
# Файлы ОС
# ==========================
.DS_Store
Thumbs.db
desktop.ini

# ==========================
# Конфигурационные файлы
# ==========================
config_*.json
EOF